# API (APP_ prefix)
APP_ENVIRONMENT=development
APP_API_HOST=0.0.0.0
APP_API_PORT=8000
APP_CORS_ORIGINS=*
APP_DATABASE_URL=sqlite:///./lysergic.db
APP_LOG_LEVEL=INFO

# Fireworks AI provider
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b
FIREWORKS_TIMEOUT=30

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# Codespaces: comma-separated origins the API may be called from (unprefixed; consumed by
# docker-compose). Include the forwarded web URL, e.g.
# CORS_ORIGINS=http://localhost:3000,http://web:3000,https://<codespace>-3000.app.github.dev
CORS_ORIGINS=
